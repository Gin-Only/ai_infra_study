using namespace AscendC;

constexpr int32_t MAX_THREADS_PER_BLOCK = 1024;
// constexpr int32_t WARP_SIZE = 32;
// constexpr int32_t MAX_ELEMENTS_PER_THREAD = 4;
// constexpr int32_t MAX_WARPS = MAX_THREADS_PER_BLOCK / WARP_SIZE;
// constexpr int32_t DATA_ALIGN_BYTES = 32;


extern "C"
__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void linearize_cache_indices_from_row_idx(
    __gm__ int64_t* cache_hash_size_cumsum;
    __gm__ uint32_t* update_table_indices;
    __gm__ uint32_t* update_row_indices;
    __gm__ uint32_t* linear_cache_indices;
    uint32_t index_total_length;
    uint32_t cumsum_length;
){
    int32_t gid = blockIdx.x * blockDim.x + threadIdx.x;
    if (gid >= index_total_length) {
        return;
    }

    int32_t tableId  = update_table_indices[gid];
    T       rowId    = update_row_indices[gid];
    int64_t sentinel = cache_hash_size_cumsum[cumsum_length - 1];
    int64_t offset   = cache_hash_size_cumsum[tableId];

    if (offset >= 0 && rowId >= static_cast<T>(0)) {
        linear_cache_indices[gid] = static_cast<T>(offset + static_cast<int64_t>(rowId));
    } else {
        linear_cache_indices[gid] = static_cast<T>(sentinel);
    }

}
#endif  // SIMT_KERNEL_H
