#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
最小验证脚本：检查 linearize_cache_indices_from_row_idx 是否在昇腾环境可调用。
在昇腾机器上运行：python check_op_available.py
"""
import sysconfig
import fbgemm_gpu  # noqa: F401
import torch
import torch_npu  # noqa: F401

torch.ops.load_library(f"{sysconfig.get_path('purelib')}/libfbgemm_npu_api.so")

DEVICE = "npu:0"

# ── 步骤1：确认 op 已注册 ──────────────────────────────────────────────────
print("已注册的 fbgemm ops（含 linearize）：")
for name in dir(torch.ops.fbgemm):
    if "linearize" in name:
        print(f"  torch.ops.fbgemm.{name}")

# ── 步骤2：用最小输入在 CPU 上调用，确认 op 本身可找到 ──────────────────────
print("\n[CPU] 调用 linearize_cache_indices_from_row_idx ...")
cumsum    = torch.tensor([0, 12, 24], dtype=torch.int64)
table_idx = torch.tensor([0, 1],     dtype=torch.int32)
row_idx   = torch.tensor([3, 5],     dtype=torch.int32)

try:
    result_cpu = torch.ops.fbgemm.linearize_cache_indices_from_row_idx(
        cumsum, table_idx, row_idx
    )
    print(f"  CPU 调用成功，输出: {result_cpu.tolist()}  dtype={result_cpu.dtype}")
    print(f"  注意：CPU 实现为 stub，输出为未初始化值（empty_like），属正常现象")
except Exception as e:
    print(f"  CPU 调用失败: {e}")

# ── 步骤3：在 NPU 上调用，确认 dispatch 是否命中 NPU kernel ─────────────────
print(f"\n[NPU] 调用 linearize_cache_indices_from_row_idx on {DEVICE} ...")
cumsum_npu    = cumsum.to(DEVICE)
table_idx_npu = table_idx.to(DEVICE)
row_idx_npu   = row_idx.to(DEVICE)

try:
    result_npu = torch.ops.fbgemm.linearize_cache_indices_from_row_idx(
        cumsum_npu, table_idx_npu, row_idx_npu
    )
    print(f"  NPU 调用成功，输出: {result_npu.cpu().tolist()}  dtype={result_npu.dtype}")
    print(f"  输出设备: {result_npu.device}")

    # 期望值（参考实现）：[3+0, 5+12] = [3, 17]
    expected = torch.tensor([3, 17], dtype=torch.int32)
    if torch.equal(result_npu.cpu(), expected):
        print(f"  结果正确！NPU kernel 已实现并可用。")
    else:
        print(f"  结果与期望不符（期望 {expected.tolist()}），NPU kernel 可能未实现或为 stub。")
except Exception as e:
    print(f"  NPU 调用失败: {e}")
    print(f"  => linearize_cache_indices_from_row_idx 尚未在 NPU 上注册，需要实现 NPU kernel。")
