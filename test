def build_cache_hash_size_cumsum(num_tables, table_cache_size, uncached_tables=None):
    """
    构造 cache_hash_size_cumsum。
    uncached_tables: set of table indices that are not cached (cumsum entry = -1).
    返回 numpy array [T+1], int64。
    """
    sizes = []
    cumsum = 0
    result = [0]
    for t in range(num_tables):
        if uncached_tables and t in uncached_tables:
            sizes.append(-1)
            result.append(-1)  # 占位，后续修正
        else:
            sizes.append(table_cache_size)
            cumsum += table_cache_size
            result.append(cumsum)

    # 重新构造：按 FBGEMM 语义，未缓存表的 cumsum 值为 -1，
    # 已缓存表的 cumsum 值为其在全局空间的起始偏移（跳过未缓存表）
    cumsum_arr = np.zeros(num_tables + 1, dtype=np.int64)
    offset = 0
    for t in range(num_tables):
        cumsum_arr[t] = -1 if (uncached_tables and t in uncached_tables) else offset
        if not (uncached_tables and t in uncached_tables):
            offset += table_cache_size
    cumsum_arr[num_tables] = offset  # 哨兵值 = 总缓存大小
    return cumsum_arr


def linearize_cache_indices_from_row_idx_ref(
    cache_hash_size_cumsum: np.ndarray,
    update_table_indices: np.ndarray,
    update_row_indices: np.ndarray,
) -> np.ndarray:
    """CPU 参考实现，与 CUDA kernel 逻辑完全对应。"""
    N = len(update_row_indices)
    T = len(cache_hash_size_cumsum) - 1
    max_offset = cache_hash_size_cumsum[T]
    output = np.empty(N, dtype=update_row_indices.dtype)
    for i in range(N):
        t = update_table_indices[i]
        curr_offset = cache_hash_size_cumsum[t]
        if curr_offset >= 0 and update_row_indices[i] >= 0:
            output[i] = update_row_indices[i] + curr_offset
        else:
            output[i] = max_offset
    return output


def generate_test_data(num_tables, table_cache_size, num_updates, index_dtype,
                       uncached_tables=None, pruned_ratio=0.0):
    """
    生成测试数据。
    pruned_ratio: update_row_indices 中负值（剪枝行）的比例。
    """
    cumsum = build_cache_hash_size_cumsum(num_tables, table_cache_size, uncached_tables)

    if num_updates == 0:
        table_indices = np.array([], dtype=np.int32)
        row_indices = np.array([], dtype=np.int32)
        return cumsum, table_indices, row_indices

    table_indices = np.random.randint(0, num_tables, size=num_updates).astype(np.int32)

    # 生成行索引，部分可为负（模拟剪枝）
    row_indices = np.random.randint(0, max(table_cache_size, 1), size=num_updates).astype(np.int32)
    if pruned_ratio > 0.0:
        pruned_mask = np.random.rand(num_updates) < pruned_ratio
        row_indices[pruned_mask] = -1

    return cumsum, table_indices, row_indices


def run_test(cumsum_np, table_indices_np, row_indices_np, index_dtype):
    """核心测试逻辑：对比 CPU 参考实现与 NPU 算子输出。"""
    # CPU 参考结果
    ref_output = linearize_cache_indices_from_row_idx_ref(
        cumsum_np, table_indices_np, row_indices_np
    )

    # 转换为 Tensor 并移至 NPU
    cumsum_t = torch.from_numpy(cumsum_np).to(torch.int64).to(DEVICE)
    table_indices_t = torch.from_numpy(table_indices_np).to(index_dtype).to(DEVICE)
    row_indices_t = torch.from_numpy(row_indices_np).to(index_dtype).to(DEVICE)
    print(cumsum_t)
    print(table_indices_t)
    print(row_indices_t)
    # 调用 NPU 算子
    npu_output = torch.ops.fbgemm.linearize_cache_indices_from_row_idx(
        cumsum_t, table_indices_t, row_indices_t
    )
    print(npu_output)

    # 验证输出形状
    assert npu_output.shape == row_indices_t.shape, \
        f"Shape mismatch: expected {row_indices_t.shape}, got {npu_output.shape}"

    # 验证输出 dtype 与 update_row_indices 一致
    assert npu_output.dtype == index_dtype, \
        f"dtype mismatch: expected {index_dtype}, got {npu_output.dtype}"

    # 数值对比
    ref_t = torch.from_numpy(ref_output).to(index_dtype)
    npu_cpu = npu_output.cpu()
    assert torch.equal(ref_t, npu_cpu), \
        f"Value mismatch:\nref:  {ref_t}\nnpu:  {npu_cpu}"


