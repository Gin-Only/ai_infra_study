@pytest.mark.parametrize("index_dtype", INDEX_DTYPE_LIST)
def test_all_tables_uncached(index_dtype):
    """所有表均未缓存，所有输出应为哨兵值 0（总缓存大小为 0）。"""
    num_tables = 4
    table_cache_size = 12
    num_updates = 16
    uncached_tables = set(range(num_tables))

    cumsum, table_indices, row_indices = generate_test_data(
        num_tables, table_cache_size, num_updates, index_dtype,
        uncached_tables=uncached_tables
    )
    run_test(cumsum, table_indices, row_indices, index_dtype)

    # 额外验证：所有输出均为哨兵值（= cumsum[-1] = 0）
    cumsum_t = torch.from_numpy(cumsum).to(torch.int64).to(DEVICE)
    table_indices_t = torch.from_numpy(table_indices).to(index_dtype).to(DEVICE)
    row_indices_t = torch.from_numpy(row_indices).to(index_dtype).to(DEVICE)
    npu_output = torch.ops.fbgemm.linearize_cache_indices_from_row_idx(
        cumsum_t, table_indices_t, row_indices_t
    )
    sentinel = int(cumsum[-1])
    assert (npu_output.cpu() == sentinel).all(), \
        "All outputs should be sentinel value when all tables are uncached"


