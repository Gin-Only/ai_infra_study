    expected      = np.array([10, 2, 3, 7, 13, 16, 17, 21, 36, 36, 36, 36, 29, 25, 24, 28], dtype=np.int32)

    cumsum_t = torch.from_numpy(cumsum).to(torch.int64).to(DEVICE)
