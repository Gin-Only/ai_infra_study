@pytest.mark.parametrize("is_mxrec", [True, False])
def test_empty_updates(is_mxrec):
    """N=0 时算子应返回空 Tensor，不崩溃。"""
    cumsum = build_cache_hash_size_cumsum(4, 12)
    cumsum_t = torch.from_numpy(cumsum).to(torch.int64).to(DEVICE)
    table_indices_t = torch.zeros(0, dtype=torch.int64).to(DEVICE)
    row_indices_t = torch.zeros(0, dtype=torch.int64).to(DEVICE)

    if is_mxrec:
        npu_output = torch.ops.mxrec.linearize_cache_indices_from_row_idx(
            cumsum_t, table_indices_t, row_indices_t
        )
    else:
        npu_output = torch.ops.fbgemm.linearize_cache_indices_from_row_idx(
            cumsum_t, table_indices_t, row_indices_t
        )
    assert npu_output.numel() == 0, "Output should be empty when N=0"
    assert npu_output.dtype == torch.int64


