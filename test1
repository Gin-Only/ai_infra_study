@pytest.mark.parametrize("index_dtype", INDEX_DTYPE_LIST)
@pytest.mark.parametrize("is_mxrec", [True, False])
def test_uncached_tables(index_dtype, is_mxrec):
    """部分表未缓存（cumsum=-1），对应记录应输出哨兵值。"""
    cumsum, table_indices, row_indices = generate_test_data(
        num_tables=4, table_cache_size=12, num_updates=32,
        uncached_tables={1, 3}
    )
    run_test(cumsum, table_indices, row_indices, index_dtype, is_mxrec)


@pytest.mark.parametrize("index_dtype", INDEX_DTYPE_LIST)
@pytest.mark.parametrize("is_mxrec", [True, False])
def test_all_tables_uncached(index_dtype, is_mxrec):
    """所有表均未缓存，所有输出应为哨兵值 0。"""
    num_tables = 4
    cumsum, table_indices, row_indices = generate_test_data(
        num_tables=num_tables, table_cache_size=12, num_updates=16,
        uncached_tables=set(range(num_tables))
    )
    run_test(cumsum, table_indices, row_indices, index_dtype, is_mxrec)

    # 额外验证：所有输出均为哨兵值（= 0，因为全部未缓存）
    npu_result = get_result(
        torch.device(DEVICE), cumsum, table_indices, row_indices, index_dtype, is_mxrec
    )
    sentinel = int(cumsum[-1])
    assert (npu_result == sentinel).all(), \
        f"All outputs should be sentinel {sentinel}, got {npu_result}"


