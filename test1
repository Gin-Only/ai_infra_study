# 失败原因分析（基于 test_result.txt）：
#
# 原始测试直接在 NPU 上调用 torch.ops.fbgemm.linearize_cache_indices_from_row_idx，
# 该算子的 NPU 实现尚未完成（kernel 未移植），empty_like 分配的输出内存未被填充，
# 导致所有 num_updates > 0 的用例输出为未初始化的垃圾值。
#
# 修复方案（参考 test_dense_to_jagged.py 模板）：
#   - CPU golden：torch.ops.fbgemm（在 cpu 设备上）
#   - NPU 被测：torch.ops.mxrec（在 npu:0 设备上）
#   两者结果做精确数值对比，与模板保持一致。
# ==============================================================================
import itertools
import logging
import sysconfig

import pytest
import fbgemm_gpu
import numpy as np
import torch_npu
import torch

DEVICE = "npu:0"
logging.getLogger().setLevel(logging.INFO)
torch.ops.load_library(f"{sysconfig.get_path('purelib')}/libfbgemm_npu_api.so")

# 测试参数：表数量
NUM_TABLES_LIST = [1, 4, 8, 16]
# 测试参数：每张表的缓存容量
TABLE_CACHE_SIZE_LIST = [12, 64, 256]
# 测试参数：更新记录数量 N
NUM_UPDATES_LIST = [0, 1, 16, 128, 1024]
# 测试参数：索引数据类型
INDEX_DTYPE_LIST = [torch.int32, torch.int64]

PARAM_LIST = list(itertools.product(NUM_TABLES_LIST, TABLE_CACHE_SIZE_LIST, NUM_UPDATES_LIST, INDEX_DTYPE_LIST))

# 边界测试用例：(num_tables, table_cache_size, num_updates)
EDGE_CASE_PARAMS = [
    (1, 1, 1),       # 最小规模
    (1, 1, 0),       # 空更新
    (2, 10, 5),      # 含未缓存表
    (32, 512, 2048), # 较大规模
]


def build_cache_hash_size_cumsum(num_tables, table_cache_size, uncached_tables=None):
    """
    构造 cache_hash_size_cumsum [T+1], int64。
    未缓存表的 cumsum 值为 -1，已缓存表为其在全局空间的起始偏移。
    最后一个元素为哨兵值（总缓存大小）。
    """
    cumsum_arr = np.zeros(num_tables + 1, dtype=np.int64)
    offset = 0
    for t in range(num_tables):
        if uncached_tables and t in uncached_tables:
            cumsum_arr[t] = -1
        else:
            cumsum_arr[t] = offset
            offset += table_cache_size
    cumsum_arr[num_tables] = offset  # 哨兵值
    return cumsum_arr


def generate_test_data(num_tables, table_cache_size, num_updates,
                       uncached_tables=None, pruned_ratio=0.0):
    """生成测试数据，pruned_ratio 控制负索引（剪枝行）的比例。"""
    cumsum = build_cache_hash_size_cumsum(num_tables, table_cache_size, uncached_tables)

    if num_updates == 0:
        return cumsum, np.array([], dtype=np.int32), np.array([], dtype=np.int32)

    table_indices = np.random.randint(0, num_tables, size=num_updates).astype(np.int32)
    row_indices = np.random.randint(0, max(table_cache_size, 1), size=num_updates).astype(np.int32)
    if pruned_ratio > 0.0:
        row_indices[np.random.rand(num_updates) < pruned_ratio] = -1

    return cumsum, table_indices, row_indices


def get_result(device, cumsum_np, table_indices_np, row_indices_np, index_dtype, is_mxrec=False):
    """在指定设备上执行算子并返回结果（cpu 上）。"""
    cumsum_t = torch.from_numpy(cumsum_np).to(torch.int64).to(device)
    table_indices_t = torch.from_numpy(table_indices_np).to(index_dtype).to(device)
    row_indices_t = torch.from_numpy(row_indices_np).to(index_dtype).to(device)

    if is_mxrec:
        result = torch.ops.mxrec.linearize_cache_indices_from_row_idx(
            cumsum_t, table_indices_t, row_indices_t
        )
    else:
        result = torch.ops.fbgemm.linearize_cache_indices_from_row_idx(
            cumsum_t, table_indices_t, row_indices_t
        )
    return result.cpu()


def run_test(cumsum_np, table_indices_np, row_indices_np, index_dtype, is_mxrec=False):
    """核心测试逻辑：CPU fbgemm golden vs NPU mxrec/fbgemm 输出。"""
    golden = get_result(
        torch.device("cpu"), cumsum_np, table_indices_np, row_indices_np, index_dtype, False
    )
    npu_result = get_result(
        torch.device(DEVICE), cumsum_np, table_indices_np, row_indices_np, index_dtype, is_mxrec
    )

    assert npu_result.shape == golden.shape, \
        f"Shape mismatch: expected {golden.shape}, got {npu_result.shape}"
    assert npu_result.dtype == index_dtype, \
        f"dtype mismatch: expected {index_dtype}, got {npu_result.dtype}"
    assert torch.equal(golden, npu_result), \
        f"Value mismatch:\ngolden: {golden}\nnpu:    {npu_result}"


# ============================================================
# 主功能测试
# ============================================================

@pytest.mark.parametrize("num_tables,table_cache_size,num_updates,index_dtype", PARAM_LIST)
@pytest.mark.parametrize("is_mxrec", [True, False])
def test_linearize_cache_indices_from_row_idx(num_tables, table_cache_size, num_updates,
                                               index_dtype, is_mxrec):
    """基本功能测试：全部表均已缓存，无剪枝行。"""
    cumsum, table_indices, row_indices = generate_test_data(
        num_tables, table_cache_size, num_updates
    )
    run_test(cumsum, table_indices, row_indices, index_dtype, is_mxrec)


