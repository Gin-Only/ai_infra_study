    run_test(cumsum, table_indices, row_indices, index_dtype, is_mxrec)


@pytest.mark.parametrize("index_dtype", INDEX_DTYPE_LIST)
@pytest.mark.parametrize("is_mxrec", [True, False])
def test_all_pruned_row_indices(index_dtype, is_mxrec):
    """所有 update_row_indices 均为 -1，所有输出应为哨兵值。"""
    num_tables = 4
    table_cache_size = 64
    num_updates = 32
    cumsum = build_cache_hash_size_cumsum(num_tables, table_cache_size)
    table_indices = np.random.randint(0, num_tables, size=num_updates).astype(np.int32)
    row_indices = np.full(num_updates, -1, dtype=np.int32)

    run_test(cumsum, table_indices, row_indices, index_dtype, is_mxrec)

    # 额外验证：所有输出均为哨兵值
    npu_result = get_result(
        torch.device(DEVICE), cumsum, table_indices, row_indices, index_dtype, is_mxrec
    )
    sentinel = int(cumsum[-1])
    assert (npu_result == sentinel).all(), \
        f"All outputs should be sentinel {sentinel}, got {npu_result}"


