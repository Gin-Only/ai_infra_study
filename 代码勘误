    {
        int32_t elementsPerBlock = BLOCK_SIZE;
        int64_t totalBlocks = (totalLength + elementsPerBlock - 1) / elementsPerBlock;
        if (totalBlocks == 0) {
            totalBlocks = 1; // 有多少个数据块
