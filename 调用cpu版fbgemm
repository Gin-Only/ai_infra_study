    row_indices_t   = torch.from_numpy(row_indices).int().cpu()

    # 你要的算子 ✅
    output = torch.ops.fbgemm.linearize_cache_indices_from_row_idx(
        cumsum_t, table_indices_t, row_indices_t
    )
